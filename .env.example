# ========== 持仓同步配置 Position Sync ==========
# 持仓同步间隔（秒）
# Position sync interval (seconds)
POSITION_SYNC_INTERVAL_SECS=0
# 仓位平衡检查间隔（秒）
# Position balance check interval (seconds)
POSITION_BALANCE_INTERVAL_SECS=0
# 不平衡阈值
# Imbalance threshold
POSITION_BALANCE_THRESHOLD=99999.0
# 最小总持仓要求
# Minimum total position requirement
POSITION_BALANCE_MIN_TOTAL=5.0

# ========== 倒计时策略配置 Countdown Strategy ==========
# 倒计时窗口开始时间（秒，距离结束），默认 10
# Countdown window start time (seconds from end), default 10
COUNTDOWN_WINDOW_MAX_SEC=10
# 倒计时窗口结束时间（秒，距离结束），默认 5
# Countdown window end time (seconds from end), default 5
COUNTDOWN_WINDOW_MIN_SEC=5

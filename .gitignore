# Ignore everything by default, then allow Rust source files only
*
!*/
!.gitignore
!*.rs
!**/*.rs

# Allow specific files that should remain tracked
!.env.example
!Cargo.lock
!Cargo.toml
!README.md
!README.zh-CN.md
!gitstart.sh
!license.key
!src/index.html
!src/main.rs.bak
!start.sh

# Existing explicit ignores are redundant under the above rule,
# but kept for clarity when non-rs files are still present.

# Build artifacts
/target/

# IDE and OS junk
.DS_Store
.idea/
.vscode/

# Secrets and local config
.env

# Logs
*.log
bot.log

